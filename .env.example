
# ╔══════════════════════════════════════════════════════════════╗
# ║         JARVIS ULTIMATE 2026 — Файл настроек (.env)          ║
# ║  1. Скопируй: cp .env.example .env                           ║
# ║  2. Заполни Telegram данные ниже                             ║
# ║  3. Запусти: python main.py                                  ║
# ╚══════════════════════════════════════════════════════════════╝


# ══════════════════════════════════════════════════════════════
# 📱 TELEGRAM
# Получи API_ID и API_HASH на: https://my.telegram.org → API development tools
# ══════════════════════════════════════════════════════════════
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+79001234567

# Токен бота
TELEGRAM_BOT_TOKEN=


# ══════════════════════════════════════════════════════════════
# ⚡ НЕЙРОСЕТЬ — OpenRouter (единственная, основная)
#
# Получить/обновить ключ: https://openrouter.ai/keys
# Сменить модель: замени OPENROUTER_MODEL на любую с openrouter.ai/models
# ══════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=
OPENROUTER_MODEL=


# ══════════════════════════════════════════════════════════════
# 🔌 СВОЯ НЕЙРОСЕТЬ (необязательно)
# Любой OpenAI-совместимый API: LM Studio, RunPod, свой сервер
# Формат: ИМЯ|АДРЕС_API|API_КЛЮЧ|НАЗВАНИЕ_МОДЕЛИ
# Пример: МойAI|http://localhost:1234/v1|no-key|llama-3-8b
# ══════════════════════════════════════════════════════════════
CUSTOM_LLM_1=
CUSTOM_LLM_2=
CUSTOM_LLM_3=


# ══════════════════════════════════════════════════════════════
# 🔍 ПОИСК (необязательно)
# Без Tavily работает через DuckDuckGo бесплатно.
# Tavily даёт лучшие результаты: https://tavily.com
# ══════════════════════════════════════════════════════════════
TAVILY_API_KEY=


# ══════════════════════════════════════════════════════════════
# 📁 GITHUB (необязательно — для команды «Джарвис, запушь»)
# ══════════════════════════════════════════════════════════════
GITHUB_REPO_PATH=/путь/до/репозитория
GITHUB_REMOTE=origin
GITHUB_BRANCH=main

# ══════════════════════════════════════════════════════════════
# 👤 ВЛАДЕЛЕЦ И ГРУППА (для отправки файлов через личку)
#
# OWNER_ID — твой Telegram ID (только ты можешь отправлять файлы)
# Узнай свой ID: напиши боту @userinfobot в Telegram
#
# DEFAULT_GROUP_ID — ID группы куда отправлять файлы по умолчанию
# Узнай ID группы: добавь @userinfobot в группу, он пришлёт ID
# ID группы обычно начинается с -100...
# ══════════════════════════════════════════════════════════════
OWNER_ID=0
DEFAULT_GROUP_ID=0
